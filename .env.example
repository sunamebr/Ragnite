# --- Providers (set what you have; everything degrades gracefully) ---------
ANTHROPIC_API_KEY=            # generation (Claude) — recommended
VOYAGE_API_KEY=               # embeddings — recommended
# OPENAI_API_KEY=             # alternative embeddings + generation
# OPENAI_BASE_URL=http://localhost:11434/v1   # point at Ollama/vLLM/etc.
# COHERE_API_KEY=             # only for RAGNITE_RERANKER=cohere

# --- Ragnite ----------------------------------------------------------------
# RAGNITE_DATA_DIR=.ragnite
# RAGNITE_COLLECTION=default
# RAGNITE_EMBEDDER=auto        # auto | voyage | openai | local | fake | none
# RAGNITE_EMBEDDING_MODEL=
# RAGNITE_LLM=auto             # auto | anthropic | openai | none
# RAGNITE_LLM_MODEL=claude-opus-4-8
# RAGNITE_STORE=native         # native | qdrant
# QDRANT_URL=http://localhost:6333
# RAGNITE_RERANKER=none        # none | cohere | voyage | llm
# RAGNITE_CONTEXTUAL=0         # 1 = LLM-written chunk context at ingest time
# RAGNITE_CHUNK_SIZE=1600
# RAGNITE_CHUNK_OVERLAP=200
# RAGNITE_TOP_K=6

# --- Memory engine ------------------------------------------------------------
# RAGNITE_MEMORY_BUDGET=2000   # context-packer token budget
# RAGNITE_CACHE_THRESHOLD=0.90 # semantic cache similarity cutoff
# RAGNITE_CACHE_TTL_DAYS=7

# --- HTTP server -------------------------------------------------------------
# RAGNITE_HOST=127.0.0.1
# RAGNITE_PORT=8000
# RAGNITE_API_KEY=             # bearer token; empty = no auth (local only!)
